APP_TITLE=RE Store
APP_VERSION=1.0.0
DEBUG=False

# For local dev (outside Docker):
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/re_store

# For Docker Compose (db = service name):
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/re_store

SECRET_KEY=your-secret-key-here

# CORS: comma-separated list of allowed origins
# Local dev:   CORS_ORIGINS=http://localhost:5173
# Docker:      CORS_ORIGINS=http://localhost
CORS_ORIGINS=http://localhost
