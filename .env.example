APP_TITLE=RE Store
APP_VERSION=1.0.0
DEBUG=False

# For local dev (outside Docker):
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/re_store

# For Docker Compose (db = service name):
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/re_store

SECRET_KEY=your-secret-key-here

# Cloudinary (загрузка изображений) — https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# CORS: comma-separated list of allowed origins
# Local dev:   CORS_ORIGINS=http://localhost:5173
# Docker:      CORS_ORIGINS=http://localhost
CORS_ORIGINS=http://localhost

# --- AI: сводка по отзывам (OpenAI Chat Completions) ---
# Оставьте пустым, если фича не нужна — эндпоинт вернёт понятную ошибку.
OPENAI_API_KEY=
# AI_REVIEWS_API_URL=https://api.openai.com/v1/chat/completions
# AI_REVIEWS_MODEL=gpt-4o-mini
# AI_REVIEWS_MIN_COUNT=3
# AI_REVIEWS_MAX_FETCH=40
# AI_REVIEWS_MAX_CONTEXT_CHARS=12000
# AI_REVIEWS_PER_REVIEW_MAX_CHARS=800
# AI_REVIEWS_TIMEOUT_SEC=60
